generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("MYSQL_URI")
}

// define models
enum UserStatus {  // for table User
  active
  blocked
}

enum UserRole { // for table User
  user
  admin
}

// define Table User
model User {
  id BigInt @id @default(autoincrement())

  isDeleted Boolean @default(false)
  isProfileComplete Boolean @default(false)
  userName String? @unique // use for profile/username
  email String @unique // not null
  passwordHash String? @db.VarChar(255)
  status UserStatus @default(active)  // allow user uses system
  role UserRole @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  // 1-1 relation
  profile Profile?
  // 1-N relation
  posts Post[]
  accounts Account[]

  createdTags PostTag[] @relation("TagsCreated")
  receivedTags PostTag[] @relation("TagsReceived")

  inviterUsers PostCollaborator[] @relation("inviterUser")
  inviteeUsers PostCollaborator[] @relation("inviteeUser")

  // Friendship (2 chiều, lưu 2 dòng A->B và B->A)
  friendships Friendship[] @relation("FriendshipUser")
  friendOf    Friendship[] @relation("FriendshipFriend")

  // Friend request (1 chiều: sender -> receiver)
  sentFriendRequests     FriendRequest[] @relation("FriendRequestSender")
  receivedFriendRequests FriendRequest[] @relation("FriendRequestReceiver")

  // Block user
  blockedUsers   UserBlock[] @relation("UserBlockBlocker")
  blockedByUsers UserBlock[] @relation("UserBlockBlocked")

  // Reaction on post
  postReactions PostReaction[]

  // Comment user đã viết
  comments Comment[]

}

enum AuthType {
  oauth
  credential
}

enum AuthProvider {
  google
  facebook
  github
}

model Account {
  id BigInt @id @default(autoincrement())

  userId BigInt
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  type AuthType // Oauth or credentials
  provider AuthProvider // google, facebook, github
  providerAccountId String // id credential GG/FB provide for user

  // token
  access_token      String?      @db.Text
  refresh_token     String?      @db.Text
  id_token          String?      @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?

  @@unique([provider, providerAccountId])
}


enum GenderProfile {
  male
  female
  other
}

// define table Profile
model Profile {
  id BigInt @id @default(autoincrement())

  userId BigInt @unique
  user User @relation(fields: [userId], references: [id])

  displayName String @db.VarChar(255)
  phoneNumber String? @unique  @db.VarChar(20)

  avatar String? @db.VarChar(255)
  avatarId String? @db.VarChar(255)  // store public_id of avatar in cloudinary

  coverImage String? @db.VarChar(255)
  coverImageId String? @db.VarChar(255)  // store public_id of coverImage in cloudinary

  bio String?
  gender GenderProfile @default(other)
  birthDay DateTime?
  location String? @db.VarChar(255)
  website String? @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
}

// define table PostPrivacy
model PostPrivacy {
  id Int @id @default(autoincrement())
  name String // example: public, friends, private
  description String

  // 1-N relation
  posts Post[]
}


// define table PostBlock
model PostBlock {
  id BigInt @id @default(autoincrement())

  postId BigInt
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  type String
  position Int  // importance -> sort priority of content post

  content Json

  @@index([postId, position]) // add index for quick query
}


enum TypeFeeling {
  feeling
  activity
}

// define table FeelingMaster
model FeelingMaster {
  id Int @id @default(autoincrement())
  type TypeFeeling
  displayText String @db.VarChar(50)
  icon String @db.VarChar(50)

}


// define table EventCategory
model EventCategory {
  id Int @id @default(autoincrement())
  keyName String @db.VarChar(255)
  displayName String @db.VarChar(500)
  icon String @db.VarChar(50)

  // 1-N relation
  eventMasters EventMaster[]
}

// define table EventMaster
model EventMaster {
  id Int @id @default(autoincrement())

  eventCategoryId Int
  eventCategory EventCategory @relation(fields: [eventCategoryId], references: [id])

  keyName String @db.VarChar(255)
  displayText String @db.VarChar(500)
  icon String @db.VarChar(50)

}


// define table Post
model Post {
  id BigInt @id @default(autoincrement())

  userId BigInt
  user User @relation(fields: [userId], references: [id])

  privacyId Int
  postPrivacy PostPrivacy @relation(fields: [privacyId], references: [id])

  isDeleted Boolean @default(false)
  isEdited Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  // 1-N relation
  postBlocks PostBlock[]
  postTags PostTag[]
  postCollaborators PostCollaborator[]
  postReactions PostReaction[]
  comments Comment[]

  @@index([userId, createdAt])
  @@index([isDeleted])  // choose posts do not delete yet
}

// define table PostTag
model PostTag {
  id Int @id @default(autoincrement())

  postId BigInt
  post Post @relation(fields: [postId], references: [id])

  taggedBy BigInt
  userBy User @relation("TagsCreated", fields: [taggedBy], references: [id])

  taggedUserId BigInt
  taggedUser User @relation("TagsReceived",fields: [taggedUserId], references: [id])

  createdAt DateTime @default(now())

  @@unique([postId, taggedUserId]) // 1 record only have 1 taggedUser
}

// define table postCollaborator
enum CollaboratorStatus {
  pending
  accepted
  rejected
}

model PostCollaborator {
  id BigInt @id @default(autoincrement())

  postId BigInt
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  inviterId BigInt
  inviter User @relation("inviterUser", fields: [inviterId], references: [id])

  inviteeId BigInt
  invitee User @relation("inviteeUser", fields: [inviteeId], references: [id])

  joinedAt DateTime @default(now())
  respondedAt DateTime?

  status CollaboratorStatus @default(pending)

  // create index
  @@unique([postId, inviteeId])
}


// define table Friendship
// Lưu 2 dòng (A,B) và (B,A) cho quan hệ bạn bè 2 chiều
// CHECK userId != friendId — enforce ở application layer (Prisma không support CHECK constraint)
model Friendship {
  userId BigInt
  user User @relation("FriendshipUser", fields: [userId], references: [id], onDelete: Cascade)

  friendId BigInt
  friend User @relation("FriendshipFriend", fields: [friendId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, friendId])
  @@index([userId, createdAt]) // phân trang theo thời gian kết bạn
}


// define table FriendRequest
enum FriendRequestStatus {
  pending
  accepted
  rejected
}

// CHECK senderId != receiverId — enforce ở application layer
// Xóa row sau khi accept/reject hoặc sau N ngày (cron job)
model FriendRequest {
  id BigInt @id @default(autoincrement())

  senderId BigInt
  sender User @relation("FriendRequestSender", fields: [senderId], references: [id], onDelete: Cascade)

  receiverId BigInt
  receiver User @relation("FriendRequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  status FriendRequestStatus @default(pending)

  createdAt DateTime @default(now())
  respondedAt DateTime?

  @@unique([senderId, receiverId]) // giả định xóa sau khi xử lý
  @@index([receiverId, status, createdAt]) // inbox: lời mời đến mình
  @@index([senderId, status, createdAt])   // outbox: lời mời mình đã gửi
}


// define table UserBlock
model UserBlock {
  blockerId BigInt
  blocker User @relation("UserBlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)

  blockedId BigInt
  blocked User @relation("UserBlockBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([blockerId, blockedId])
  @@index([blockedId]) // check "mình có đang bị ai block không"
}


// define table ReactionMaster
// 7 loại reaction giống Facebook: like, love, care, haha, wow, sad, angry
model ReactionMaster {
  id Int @id @default(autoincrement())
  keyName String @db.VarChar(30)      // like, love, care, haha, wow, sad, angry
  displayText String @db.VarChar(50)  // Like, Love, Care, Haha, Wow, Sad, Angry
  icon String @db.VarChar(50)

  // 1-N relation
  postReactions PostReaction[]
}


// define table PostReaction
// Composite PK (postId, userId) — 1 user chỉ có 1 reaction trên 1 post (đổi emoji = update reactionId)
model PostReaction {
  postId BigInt
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId BigInt
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  reactionId Int
  reaction ReactionMaster @relation(fields: [reactionId], references: [id])

  createdAt DateTime @default(now())

  @@id([postId, userId])
}


// define table Comment
// Threading 2 cấp: top-level (parentId = null) và reply (parentId trỏ đến top-level).
// KHÔNG support nested reply (reply trên reply) — service layer enforce auto-flatten.
// Soft delete: khi user xóa, set isDeleted=true, FE render placeholder "[Đã xóa]".
model Comment {
  id BigInt @id @default(autoincrement())

  postId BigInt
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId BigInt
  user User @relation(fields: [userId], references: [id])

  // null = top-level comment. Có giá trị = reply trỏ đến top-level (không nested tiếp).
  parentId BigInt?
  parent Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  content String @db.Text
  isEdited Boolean @default(false)
  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  // Index 1: list top-level comment của 1 post theo thời gian (parentId = null filter)
  // Index 2: list replies của 1 top-level comment theo thời gian
  // Index 3: list comment của 1 user (profile page)
  @@index([postId, parentId, createdAt])
  @@index([parentId, createdAt])
  @@index([userId])
}

